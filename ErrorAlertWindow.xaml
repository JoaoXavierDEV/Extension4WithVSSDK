<Window x:Class="Extension4WithVSSDK.ErrorAlertWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Erro Detectado"
        Width="560" Height="480"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="#FF1E1E1E"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="⚠ ERRO DETECTADO!"
                   Foreground="#FFFF4444"
                   FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>

        <Border Grid.Row="1"
                Background="#FF2D2D30"
                CornerRadius="6"
                Padding="10">
            <Image x:Name="ErrorImage"
                   Stretch="Uniform"
                   RenderOptions.BitmapScalingMode="HighQuality"/>
        </Border>

        <Button Grid.Row="2"
                Content="Fechar"
                Click="CloseButton_Click"
                Width="120" Height="36"
                Margin="0,16,0,0"
                FontSize="14" FontWeight="SemiBold"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="btnBorder"
                            Background="#FFCC3333"
                            CornerRadius="4"
                            Padding="8,4">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="White"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="btnBorder" Property="Background" Value="#FFEE4444"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="btnBorder" Property="Background" Value="#FF991111"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>
    </Grid>
</Window>